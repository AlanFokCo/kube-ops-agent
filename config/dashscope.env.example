# DashScope (Alibaba Cloud Qwen) test environment variables
# Copy to dashscope.env and fill in values: cp config/dashscope.env.example config/dashscope.env
# Usage: source config/dashscope.env && ./scripts/test-dashscope.sh [dry-run|run|test-api]

# Required: DashScope API Key (from Alibaba Cloud Model Studio)
DASHSCOPE_API_KEY=sk-xxx

# DashScope OpenAI-compatible Base URL (by region)
# Beijing (China North 2):
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore: OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# US:        OPENAI_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# Qwen model name (recommended: qwen-plus, qwen-turbo, qwen-max)
OPENAI_MODEL=qwen-plus

# Optional
K8SOPS_HTTP_ADDR=:8080
K8SOPS_SKILLS_DIR=kubernetes-ops-agent/skills
K8SOPS_REPORT_DIR=kubernetes-ops-agent/report
