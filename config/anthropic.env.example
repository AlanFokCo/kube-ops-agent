# Anthropic Claude API environment variables (OpenAI-compatible)
# Copy to anthropic.env and fill in values: cp config/anthropic.env.example config/anthropic.env
# Usage: source config/anthropic.env && ./k8sops

# Required: Anthropic API Key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxx

# Required: Anthropic OpenAI-compatible base URL
OPENAI_BASE_URL=https://api.anthropic.com/v1

# Model name (e.g. claude-3-5-sonnet-20241022, claude-3-haiku-20240307)
OPENAI_MODEL=claude-3-5-sonnet-20241022

# Optional
K8SOPS_HTTP_ADDR=:8080
K8SOPS_SKILLS_DIR=kubernetes-ops-agent/skills
K8SOPS_REPORT_DIR=kubernetes-ops-agent/report

# Planning mode: unset = LLM self-planning; set path = Workflow
# K8SOPS_WORKFLOW=kubernetes-ops-agent/workflow.yaml
