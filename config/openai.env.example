# OpenAI API environment variables
# Copy to openai.env and fill in values: cp config/openai.env.example config/openai.env
# Usage: source config/openai.env && ./k8sops

# Required: OpenAI API Key (from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxx

# Optional: Model name (default gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: Custom base URL (for OpenAI-compatible proxies or Azure OpenAI)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional
K8SOPS_HTTP_ADDR=:8080
K8SOPS_SKILLS_DIR=kubernetes-ops-agent/skills
K8SOPS_REPORT_DIR=kubernetes-ops-agent/report

# Planning mode: unset = LLM self-planning; set path = Workflow
# K8SOPS_WORKFLOW=kubernetes-ops-agent/workflow.yaml
