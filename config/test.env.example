# Quick test environment variables
# Copy to test.env and fill in values: cp config/test.env.example config/test.env

# Required: OpenAI API Key
OPENAI_API_KEY=sk-xxx

# Optional
OPENAI_MODEL=gpt-4o-mini
K8SOPS_HTTP_ADDR=:8080
K8SOPS_SKILLS_DIR=kubernetes-ops-agent/skills
K8SOPS_REPORT_DIR=kubernetes-ops-agent/report

# Planning mode: unset = LLM self-planning; set path = Workflow static orchestration
# K8SOPS_WORKFLOW=kubernetes-ops-agent/workflow.yaml

# See also: config/openai.env.example, config/anthropic.env.example, config/dashscope.env.example
